<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F14"
    android:padding="20dp">

    <!-- Header / Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="ASTITVA OS"
        android:textColor="#00FFCC"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitle"
        android:layout_centerHorizontal="true"
        android:text="GOD-MODE AGENT"
        android:textColor="#8899A6"
        android:textSize="12sp"
        android:letterSpacing="0.2" />

    <!-- AI Core Status Indicator (Futuristic Glowing Orb Vibe) -->
    <LinearLayout
        android:id="@+id/coreStatusLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvSubtitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/circle_background">
            <TextView
                android:id="@+id/tvSystemState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="IDLE"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

    <!-- Dynamic Config Section (No Hardcoding) -->
    <LinearLayout
        android:id="@+id/configLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/coreStatusLayout"
        android:layout_marginTop="40dp"
        android:orientation="vertical"
        android:background="#121A22"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEURAL LINK CONFIG"
            android:textColor="#00FFCC"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Gemini/Groq API Key (Live Load)"
            android:textColorHint="#556677"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00FFCC"
            android:inputType="textPassword"
            android:textSize="14sp" />
            
        <Button
            android:id="@+id/btnSaveConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="UPDATE CONFIG LIVE"
            android:backgroundTint="#00FFCC"
            android:textColor="#0A0F14"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- System Logs / Intelligence Output -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/configLayout"
        android:layout_above="@id/tvFooter"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="#05080A"
        android:padding="10dp">
        
        <TextView
            android:id="@+id/tvLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="> ASTITVA Subsystems Initialized...\n> Waiting for neural uplink..."
            android:textColor="#00FF00"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </ScrollView>

    <!-- Required Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/tvFooter"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnVision"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="ENABLE VISION"
            android:backgroundTint="#2A3B4C"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnRoot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="ROOT MOTOR"
            android:backgroundTint="#2A3B4C"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Footer Branding -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text="Engineered by Vicky"
        android:textColor="#556677"
        android:textSize="12sp"
        android:textStyle="italic" />

</RelativeLayout>