<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Premium Light Theme (Apple-esque) -->
    <style name="Theme.Astitva" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:statusBarColor">@color/pearl_white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/pearl_white</item>
        <item name="android:windowBackground">@color/pearl_white</item>
        <item name="android:colorPrimary">@color/rose_gold</item>
        <item name="android:colorAccent">@color/accent_pink</item>
    </style>

    <!-- Glassmorphism Card Style -->
    <style name="GlassCard">
        <item name="android:background">@drawable/glass_background</item>
        <item name="android:padding">20dp</item>
        <item name="android:elevation">8dp</item>
    </style>

    <!-- Modern Button Style -->
    <style name="PremiumButton">
        <item name="android:background">@drawable/button_gradient</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:padding">14dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
